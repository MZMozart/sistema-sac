{
  "name": "atendepro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NEXT_PRIVATE_TURBOPACK=0 && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/main.cjs\"",
    "desktop:start": "electron electron/main.cjs",
    "desktop:build": "npm run build && electron-builder",
    "desktop:build:win": "npm run build && electron-builder --win nsis",
    "desktop:package:win": "electron-builder --win nsis --publish never",
    "android:add": "capacitor add android",
    "android:sync": "capacitor sync android",
    "android:open": "capacitor open android",
    "android:build:debug": "capacitor sync android && cd android && gradlew assembleDebug",
    "android:build:release": "capacitor sync android && cd android && gradlew assembleRelease"
  },
  "dependencies": {
